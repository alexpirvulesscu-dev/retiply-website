---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Retiply | AI Operations for Project-Based Businesses',
  description = 'Retiply builds operational systems that turn the daily noise of running a project-based business into clarity, automation, and control. Built by operators, for operators.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/png" href="/logo-icon.png" />

    <!-- Google Fonts: Poppins + Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Structured Data for AI/Search crawlers -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Retiply",
        "url": "https://retiply.ai",
        "description": "AI operations consultancy for project-based businesses. We build operational systems that turn daily chaos into clarity, automation, and control.",
        "founders": [
          { "@type": "Person", "name": "Alex" },
          { "@type": "Person", "name": "Ana" }
        ],
        "knowsAbout": [
          "AI automation",
          "operational systems",
          "finance automation",
          "workflow automation",
          "project-based business consulting"
        ],
        "serviceType": "AI Operations Consulting"
      }
    </script>
  </head>
  <body class="bg-brand-bg text-brand-text">
    <slot />
  </body>
</html>
