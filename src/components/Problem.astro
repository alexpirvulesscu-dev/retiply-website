---
const painPoints = [
  {
    stat: '15 hrs/week',
    heading: 'Spent on work a machine should be doing.',
    body: 'Invoice processing, data entry, chasing updates, building reports. Your team is highly capable. This is not what you hired them for.',
  },
  {
    stat: '2 weeks late',
    heading: 'By the time you see the numbers, they\'re already old.',
    body: 'Your P&L is always behind. Job statuses live in someone\'s head. You\'re making decisions on data that stopped being accurate days ago.',
  },
  {
    stat: 'Every. Single. Month.',
    heading: 'The same manual processes, repeated forever.',
    body: 'Nothing changes because there\'s never time to fix it. The business grows. The admin grows with it. And the margin quietly disappears.',
  },
];
---

<section class="py-24 px-6 bg-brand-surface">
  <div class="max-w-7xl mx-auto">

    <!-- Heading -->
    <div class="mb-16">
      <p class="section-label">The problem</p>
      <h2 class="font-poppins font-bold text-3xl md:text-5xl text-brand-text max-w-xl leading-tight">
        Sound familiar?
      </h2>
    </div>

    <!-- Pain point cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
      {painPoints.map((point) => (
        <div class="bg-brand-bg rounded-2xl p-8 flex flex-col">
          <!-- Stat — dominant element -->
          <p class="font-poppins font-bold text-4xl md:text-5xl text-brand-accent leading-none mb-5">
            {point.stat}
          </p>
          <!-- Card headline -->
          <h3 class="font-poppins font-semibold text-lg text-brand-text mb-3">
            {point.heading}
          </h3>
          <!-- Card body -->
          <p class="font-inter text-brand-muted text-sm leading-relaxed">
            {point.body}
          </p>
        </div>
      ))}
    </div>

    <!-- Closing statement — unchanged -->
    <div class="border-t border-brand-surface3 pt-12">
      <p class="font-poppins font-semibold text-xl md:text-2xl text-brand-text max-w-2xl">
        The real cost is not the chaos.
        <span class="text-brand-accent"> It is the decisions you are making blind.</span>
      </p>
    </div>

  </div>
</section>
