---
const painPoints = [
  {
    stat: '15+ hours/week',
    heading: 'Your team is doing work a computer should be doing.',
    body: 'Invoice chasing. Data entry. Copy-paste from one spreadsheet to another. Answering the same questions over and over. That\'s your best people — wasting their best hours.',
  },
  {
    stat: 'Always late',
    heading: 'By the time you see your numbers, it\'s too late to act.',
    body: 'Your P&L is two weeks old. You don\'t know which jobs made money and which ones didn\'t. You\'re guessing on pricing. And every bad decision compounds quietly.',
  },
  {
    stat: 'Every month. Every year.',
    heading: 'You\'ve been meaning to fix this for 3 years.',
    body: 'The business grows. The admin grows with it. But there\'s never a right time to stop and sort it. So nothing changes — and your margin quietly disappears.',
  },
];
---

<section class="py-24 px-6 bg-brand-surface">
  <div class="max-w-7xl mx-auto">

    <!-- Heading -->
    <div class="mb-16">
      <p class="section-label">Sound familiar?</p>
      <h2 class="font-poppins font-bold text-3xl md:text-5xl text-brand-text max-w-xl leading-tight">
        You already know something's broken. You just haven't had time to fix it.
      </h2>
    </div>

    <!-- Pain point cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
      {painPoints.map((point) => (
        <div class="bg-brand-bg rounded-2xl p-8 flex flex-col">
          <!-- Stat — dominant element -->
          <p class="font-poppins font-bold text-4xl md:text-5xl text-brand-accent leading-none mb-5">
            {point.stat}
          </p>
          <!-- Card headline -->
          <h3 class="font-poppins font-semibold text-lg text-brand-text mb-3">
            {point.heading}
          </h3>
          <!-- Card body -->
          <p class="font-inter text-brand-muted text-sm leading-relaxed">
            {point.body}
          </p>
        </div>
      ))}
    </div>

    <!-- Closing statement — unchanged -->
    <div class="border-t border-brand-surface3 pt-12">
      <p class="font-poppins font-semibold text-xl md:text-2xl text-brand-text max-w-2xl">
        The real cost is not the chaos.
        <span class="text-brand-accent"> It is the decisions you are making blind.</span>
      </p>
    </div>

  </div>
</section>
