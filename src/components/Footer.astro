---
const navLinks = [
  { label: 'What We Do', href: '#services' },
  { label: 'How We Work', href: '#how-we-work' },
  { label: 'About Us', href: '#about' },
];
const calendlyClick = "Calendly.initPopupWidget({url: 'https://calendly.com/retiply/30min', color: '#5B1FE6', textColor: '#ffffff'}); return false;";
---

<footer class="bg-[#0A0A09] border-t border-white/10 px-6 py-12">
  <div class="max-w-7xl mx-auto">

    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">

      <!-- Logo + tagline -->
      <div>
        <img src="/logo-horizontal.png" alt="Retiply" class="h-14 w-auto mb-4 brightness-0 invert" />
        <p class="font-inter text-white/40 leading-relaxed" style="font-size: 1.125rem; white-space: nowrap;">
          We remove the manual work from running your business.
        </p>
      </div>

      <!-- Nav links -->
      <nav class="flex flex-wrap gap-x-8 gap-y-3">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="font-inter text-sm text-white/50 hover:text-white transition-colors duration-200"
          >
            {link.label}
          </a>
        ))}
        <a
          href="#"
          onclick={calendlyClick}
          class="font-inter text-sm text-white/50 hover:text-white transition-colors duration-200"
        >
          Let's talk
        </a>
      </nav>

    </div>

    <!-- Contact details -->
    <div class="mt-10 pt-8 border-t border-white/10 flex flex-col sm:flex-row gap-5 sm:gap-8">
      <!-- Email -->
      <a href="mailto:hello@retiply.ai" class="flex items-center gap-3 font-inter text-white/40 hover:text-white/70 hover:underline transition-colors duration-200" style="font-size: 1rem; text-decoration: none;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#5B1FE6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2" />
          <path d="M22 4 12 13 2 4" />
        </svg>
        hello@retiply.ai
      </a>
      <!-- Phone -->
      <a href="tel:+447930949876" class="flex items-center gap-3 font-inter text-white/40 hover:text-white/70 hover:underline transition-colors duration-200" style="font-size: 1rem; text-decoration: none;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#5B1FE6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
        </svg>
        +44 7930 949876
      </a>
      <!-- Location -->
      <span class="flex items-center gap-3 font-inter text-white/40" style="font-size: 1rem;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#5B1FE6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 1 1 18 0z" />
          <circle cx="12" cy="10" r="3" />
        </svg>
        London, UK
      </span>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 pt-8 border-t border-white/10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div class="flex items-center gap-6">
        <p class="font-inter text-xs text-white/30">
          &copy; {new Date().getFullYear()} Retiply. All rights reserved.
        </p>
        <a
          href="/privacy"
          target="_blank"
          class="font-inter text-white/40 hover:underline transition-colors duration-200"
          style="font-size: 0.8rem; text-decoration: none;"
        >
          Privacy Policy
        </a>
        <a
          href="/terms"
          target="_blank"
          class="font-inter text-white/40 hover:underline transition-colors duration-200"
          style="font-size: 0.8rem; text-decoration: none;"
        >
          Terms of Service
        </a>
      </div>
      <a
        href="mailto:hello@retiply.ai"
        class="font-inter text-xs text-white/40 hover:text-white/70 transition-colors duration-200"
      >
        hello@retiply.ai
      </a>
    </div>

  </div>
</footer>
