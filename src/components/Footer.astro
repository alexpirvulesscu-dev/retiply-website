---
const navLinks = [
  { label: 'What We Do', href: '#services' },
  { label: 'How We Work', href: '#how-we-work' },
  { label: 'About Us', href: '#about' },
];
const calendlyClick = "Calendly.initPopupWidget({url: 'https://calendly.com/retiply/30min', color: '#5B1FE6', textColor: '#ffffff'}); return false;";
---

<footer class="bg-[#0A0A09] border-t border-white/10 px-6 py-12">
  <div class="max-w-7xl mx-auto">

    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">

      <!-- Logo + tagline -->
      <div>
        <img src="/logo-horizontal.png" alt="Retiply" class="h-14 w-auto mb-4 brightness-0 invert" />
        <p class="font-inter text-white/40 leading-relaxed" style="font-size: 1.125rem;">
          Helping growing businesses do more without hiring more.
        </p>
      </div>

      <!-- Nav links -->
      <nav class="flex flex-wrap gap-x-8 gap-y-3">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="font-inter text-sm text-white/50 hover:text-white transition-colors duration-200"
          >
            {link.label}
          </a>
        ))}
        <a
          href="#"
          onclick={calendlyClick}
          class="font-inter text-sm text-white/50 hover:text-white transition-colors duration-200"
        >
          Let's talk
        </a>
      </nav>

    </div>

    <!-- Bottom bar -->
    <div class="mt-10 pt-8 border-t border-white/10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div class="flex items-center gap-6">
        <p class="font-inter text-xs text-white/30">
          &copy; {new Date().getFullYear()} Retiply. All rights reserved.
        </p>
        <a
          href="/privacy"
          target="_blank"
          class="font-inter text-white/40 hover:underline transition-colors duration-200"
          style="font-size: 0.8rem; text-decoration: none;"
        >
          Privacy Policy
        </a>
        <a
          href="/terms"
          target="_blank"
          class="font-inter text-white/40 hover:underline transition-colors duration-200"
          style="font-size: 0.8rem; text-decoration: none;"
        >
          Terms of Service
        </a>
      </div>
    </div>

  </div>
</footer>
