---
const navLinks = [
  { label: 'What We Do', href: '#services' },
  { label: 'How We Work', href: '#how-we-work' },
  { label: 'About Us', href: '#about' },
  { label: 'Book a Free Call', href: '#contact' },
];
---

<footer class="bg-[#0A0A09] border-t border-white/10 px-6 py-12">
  <div class="max-w-7xl mx-auto">

    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">

      <!-- Logo + tagline -->
      <div>
        <img src="/logo-horizontal.png" alt="Retiply" class="h-14 w-auto mb-4 brightness-0 invert" />
        <p class="font-inter text-xs text-white/40 max-w-xs leading-relaxed">
          We remove the manual work from running your business.
        </p>
      </div>

      <!-- Nav links -->
      <nav class="flex flex-wrap gap-x-8 gap-y-3">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="font-inter text-sm text-white/50 hover:text-white transition-colors duration-200"
          >
            {link.label}
          </a>
        ))}
      </nav>

    </div>

    <!-- Bottom bar -->
    <div class="mt-10 pt-8 border-t border-white/10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <p class="font-inter text-xs text-white/30">
        &copy; {new Date().getFullYear()} Retiply. All rights reserved.
      </p>
      <a
        href="mailto:hello@retiply.ai"
        class="font-inter text-xs text-white/40 hover:text-white/70 transition-colors duration-200"
      >
        hello@retiply.ai
      </a>
    </div>

  </div>
</footer>
