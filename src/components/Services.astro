---
import ServicesGrid from './ServicesGrid.jsx';

const services = [
  {
    title: 'Finance & P&L Automation',
    description: 'Know exactly where your money is. Every day. Without touching a spreadsheet.',
    tags: ['Cash Flow Visibility', 'Invoice Automation', 'Job Profitability'],
    icon: 'finance',
  },
  {
    title: 'Reporting & Dashboards',
    description: 'One screen that shows you everything. Updated automatically. No chasing.',
    tags: ['Business Intelligence', 'Timesheet Tracking', 'Live Dashboards'],
    icon: 'reporting',
  },
  {
    title: 'Lead Generation & Pipeline',
    description: 'Never lose a lead again. Follow-ups happen automatically. Your team only talks to the hot ones.',
    tags: ['CRM Automation', 'Outreach Automation', 'Pipeline Tracking'],
    icon: 'leadgen',
  },
  {
    title: 'Marketing & Sales Automation',
    description: 'Your sales process runs even when you\'re on site. Quotes go out. Leads get nurtured. Jobs get closed.',
    tags: ['Email Sequences', 'Follow-up Systems', 'Sales Workflows'],
    icon: 'marketing',
  },
  {
    title: 'AI Training',
    description: 'We show your staff which AI tools save the most time and exactly how to use them.',
    tags: ['Team Workshops', 'AI Roadmapping', 'Tool Selection'],
    icon: 'ai',
  },
  {
    title: 'Frontend Experience',
    description: 'Pages that bring in leads and tools that make your team\'s job easier.',
    tags: ['Custom Web Apps', 'Landing Pages', 'Interactive Demos'],
    icon: 'frontend',
  },
];
---

<ServicesGrid client:visible cards={services} />

<style is:global>
  @media (max-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }
  @media (max-width: 640px) {
    .services-grid {
      grid-template-columns: 1fr !important;
    }
  }
  .service-card:hover {
    border-color: rgba(91,31,230,0.3) !important;
  }
  .service-card:hover .service-card-icon {
    background: rgba(91,31,230,0.15) !important;
  }
</style>
