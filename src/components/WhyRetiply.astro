---
import AnimatedQuote from './AnimatedQuote.jsx';
const quoteText = `"We're not here to sell you software. We're here to fix the part of your business that's been costing you quietly for years."`;
const founders = [
  {
    name: 'Alex',
    role: 'Operations & Strategy',
    photo: '/Alex.jpg',
  },
  {
    name: 'Ana',
    role: 'Systems & Implementation',
    photo: '/Ana.png',
  },
];
---

<section class="relative py-24 px-6 bg-brand-bg">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-stretch">

      <!-- Left: Authority text -->
      <div>
        <p class="section-label">Why Us</p>
        <h2 class="font-inter font-bold text-2xl md:text-3xl text-brand-text leading-tight mb-8">
          We've been running businesses <span class="whitespace-nowrap">like yours.</span><br />
          We know what's breaking it.
        </h2>
        <div class="space-y-5 font-inter text-base text-brand-muted leading-relaxed">
          <p>
            Between us, we have 30+ years running and operating project-based
            businesses — construction, services, trades. We've felt the pressure,
            missed the numbers, chased the invoices.
          </p>
          <p>
            Then we spent years learning how AI and automation actually work in
            the real world — not in a pitch deck, but on the floor, with real
            teams, real resistance, real change.
          </p>
          <p>
            That combination is rare. Most tech companies don't understand your
            business. Most consultants don't understand the technology. We do both.
          </p>
        </div>
      </div>

      <!-- Right: Founder cards (no stat block) -->
      <div class="flex flex-col gap-6">
        {founders.map((founder) => (
          <div class="founder-card flex-1 bg-brand-surface rounded-2xl p-10 flex items-center gap-8 cursor-default">
            <!-- Avatar -->
            <div
              class="w-24 h-24 rounded-full flex-shrink-0 overflow-hidden"
              style="box-shadow: 0 0 0 5px rgba(45,27,142,0.12);"
            >
              <img
                src={founder.photo}
                alt={founder.name}
                class="w-full h-full object-cover"
              />
            </div>
            <div>
              <p class="font-poppins font-bold text-3xl text-brand-text mb-2">
                {founder.name}
              </p>
              <p class="font-inter text-base italic text-brand-accent">
                {founder.role}
              </p>
            </div>
          </div>
        ))}
      </div>

    </div>

    <!-- Pull quote — below both columns, word-by-word reveal -->
    <blockquote class="mt-14 border-l-2 border-brand-accent pl-8">
      <AnimatedQuote
        client:visible
        text={quoteText}
        className="font-poppins font-medium text-xl md:text-2xl text-brand-accent leading-snug"
      />
    </blockquote>

  </div>

  <!-- Section transition gradient -->
  <div aria-hidden="true" class="absolute bottom-0 left-0 right-0 h-20 pointer-events-none" style="background: linear-gradient(to bottom, transparent, #E8E4DF);"></div>
</section>

<style>
  .founder-card {
    transition: transform 0.22s ease, box-shadow 0.22s ease;
  }
  .founder-card:hover {
    transform: scale(1.025);
    box-shadow: 0 0 0 2px rgba(45,27,142,0.35), 0 8px 32px rgba(45,27,142,0.10);
  }
</style>
