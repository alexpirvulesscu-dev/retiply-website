---
import AuroraBackground from './AuroraBackground.astro';
const calendlyClick = "Calendly.initPopupWidget({url: 'https://calendly.com/retiply/30min', color: '#5B1FE6', textColor: '#ffffff'}); return false;";
---

<section id="hero-section" class="relative overflow-hidden flex flex-col items-center text-center px-6 bg-brand-bg" style="height: 100dvh; max-height: 100dvh;">
  <!-- Aurora background -->
  <AuroraBackground />

  <!-- Dot grid -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="z-index: 2; background-image: radial-gradient(circle, rgba(0,0,0,0.20) 1px, transparent 1px); background-size: 28px 28px;"
  ></div>

  <!-- Three-zone layout: headline+subtitle | CTA | metrics -->
  <div class="relative z-10 w-full max-w-6xl mx-auto px-4 flex-1 flex flex-col items-center hero-inner">

    <!-- Top: headline + subtitle -->
    <div class="text-center">
      <h1
        class="text-[2rem] md:text-[4rem] lg:text-[5rem] leading-[1.15] md:leading-[1.2] tracking-tight"
        style="font-family: 'DM Sans', sans-serif; font-weight: 700; color: #1E0660; margin-bottom: 28px;"
      >
        The <span style="background: #5B1FE6; color: white; border-radius: 0.45em; padding: 0 0.28em; display: inline-block; vertical-align: baseline;">AI automations</span><br class="md:hidden" /> partner<br />
        for growing businesses
      </h1>

      <p class="font-inter text-base md:text-2xl mx-auto leading-relaxed" style="color: #222222; margin-bottom: 0; max-width: 640px;">
        We build AI software that helps you generate leads, convert sales, and scale your operations.
      </p>
    </div>

    <!-- Middle: CTA + trust note -->
    <div class="text-center hero-cta-zone">
      <a
        href="#"
        onclick={calendlyClick}
        class="inline-flex items-center gap-3 md:gap-4 bg-brand-accent text-white rounded-full font-inter font-medium hover:bg-brand-accent-light transition-colors duration-200 hero-cta-btn"
      >
        Let's talk
        <span class="bg-white rounded-full flex items-center justify-center flex-shrink-0 w-10 h-10 md:w-12 md:h-12">
          <svg width="19" height="19" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M8.5 4 12 8l-3.5 4" stroke="#2D1B8E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      </a>
      <p class="mt-4 text-xs font-inter text-brand-muted tracking-wide">
        We start with your problem. AI is how we solve it faster.
      </p>
    </div>

    <!-- Bottom: metrics -->
    <div class="w-full hero-metrics-wrap">
    <div class="hero-metrics">
      <div class="hero-metrics__col" data-index="0">
        <span class="hero-metrics__number" data-target="14" data-suffix=" hrs">0</span>
        <span class="hero-metrics__label">given back per week</span>
        <span class="hero-metrics__attribution">Socend Construct</span>
      </div>

      <div class="hero-metrics__divider" aria-hidden="true"></div>

      <div class="hero-metrics__col" data-index="1">
        <span class="hero-metrics__number" data-target="30" data-suffix="+">0</span>
        <span class="hero-metrics__label">new customers in 3 months</span>
        <span class="hero-metrics__attribution">London Dental Practice</span>
      </div>

      <div class="hero-metrics__divider" aria-hidden="true"></div>

      <div class="hero-metrics__col" data-index="2">
        <span class="hero-metrics__number" data-target="90" data-suffix=" days">0</span>
        <span class="hero-metrics__label">of cash flow visibility</span>
        <span class="hero-metrics__attribution">Aton Grid</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-metrics {
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: 960px;
    margin: 0 auto;
    gap: 48px;
  }

  .hero-metrics__col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s ease-out, transform 0.5s ease-out;
  }

  .hero-metrics__col.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .hero-metrics__divider {
    width: 1px;
    height: 72px;
    background: #D0CCC6;
    flex-shrink: 0;
  }

  .hero-metrics__number {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 2.8rem;
    color: #0A0A0A;
    line-height: 1.1;
  }

  .hero-metrics__label {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.7rem;
    color: #6B6B6B;
    margin-top: 4px;
  }

  .hero-metrics__attribution {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.6rem;
    font-style: italic;
    color: #6B6B6B;
    margin-top: 2px;
  }

  .hero-inner {
    padding-top: 18vh;
    padding-bottom: 24px;
  }

  .hero-cta-btn {
    padding: 8px 8px 8px 24px;
    font-size: 1rem;
  }

  .hero-cta-zone {
    margin-top: auto;
    margin-bottom: auto;
    padding: 0;
  }

  .hero-metrics-wrap {
    margin-top: auto;
  }

  @media (min-width: 768px) {
    .hero-inner {
      padding-top: 20vh;
      padding-bottom: 48px;
    }
    .hero-cta-btn {
      padding: 10px 10px 10px 32px;
      font-size: 1.2rem;
    }
    .hero-cta-zone {
      margin-top: auto;
      margin-bottom: auto;
      padding: 24px 0;
    }
    .hero-metrics-wrap {
      margin-top: auto;
    }
  }

  @media (max-width: 767px) {
    .hero-inner {
      padding-bottom: 32px;
    }
    .hero-cta-zone {
      margin-top: auto;
      margin-bottom: 0;
    }
    .hero-metrics {
      flex-direction: row;
      align-items: flex-start;
      gap: 4px;
      justify-content: center;
    }
    .hero-metrics__col {
      flex: 1 1 0;
      min-width: 0;
      align-items: center;
    }
    .hero-metrics__divider {
      display: none;
    }
    .hero-metrics__number {
      font-size: 1.3rem;
    }
    .hero-metrics__label {
      font-size: 0.55rem;
    }
    .hero-metrics__attribution {
      font-size: 0.45rem;
    }
  }
</style>

<script>
  function easeOutCubic(t: number): number {
    return 1 - Math.pow(1 - t, 3);
  }

  function animateCount(el: HTMLElement, target: number, suffix: string, duration: number) {
    const start = performance.now();
    function tick(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const value = Math.round(easeOutCubic(progress) * target);
      el.textContent = value + suffix;
      if (progress < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  const metricsContainer = document.querySelector('.hero-metrics');
  if (metricsContainer) {
    const cols = metricsContainer.querySelectorAll<HTMLElement>('.hero-metrics__col');

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          observer.unobserve(entry.target);

          cols.forEach((col, i) => {
            setTimeout(() => {
              col.classList.add('visible');

              const numEl = col.querySelector<HTMLElement>('.hero-metrics__number');
              if (numEl) {
                const target = parseInt(numEl.dataset.target || '0', 10);
                const suffix = numEl.dataset.suffix || '';
                animateCount(numEl, target, suffix, 1200);
              }
            }, i * 100);
          });
        });
      },
      { threshold: 0.3 }
    );

    observer.observe(metricsContainer);
  }
</script>
