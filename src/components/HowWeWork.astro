---
const steps = [
  {
    number: '01',
    title: 'Workflow Audit',
    description:
      'A free session where we look at how your business actually runs, find where time is being lost, and show you exactly what\'s worth automating.',
  },
  {
    number: '02',
    title: 'Map the Workflow',
    description:
      'Together we outline the end-to-end workflow for your business. We decide which steps stay human and which ones get automated.',
  },
  {
    number: '03',
    title: 'Proposal',
    description:
      'A clear scope and fixed price built around your specific workflow. We include alternative approaches so you can choose what fits.',
  },
  {
    number: '04',
    title: 'Build and Deploy',
    description:
      'We build, test, and hand it over live. You get weekly progress updates and a system that actually runs — not a proposal that collects dust.',
  },
  {
    number: '05',
    title: 'Ongoing Support',
    description:
      'Optional ongoing support to keep your systems sharp. The longer it runs, the more it gives back.',
  },
];
---

<section class="relative py-24 px-6 bg-brand-surface">
  <div class="max-w-7xl mx-auto">

    <!-- Heading -->
    <div class="mb-14">
      <p class="section-label">How We Work</p>
      <h2 class="font-inter font-bold text-2xl md:text-3xl text-brand-text leading-tight">
        From first conversation<br class="hidden md:block" />
        to working system.
      </h2>
    </div>

    <!-- Steps -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-5">
      {steps.map((step) => (
        <div class="bg-brand-bg rounded-2xl p-7 relative overflow-hidden">
          <!-- Large faded step number — brand blue-purple, overlapping card text slightly -->
          <span
            class="absolute -top-2 right-2 font-poppins font-bold leading-none pointer-events-none select-none"
            style="font-size: 9rem; color: rgba(45,27,142,0.10); line-height: 1;"
          >
            {step.number}
          </span>

          <!-- Title -->
          <h3 class="font-poppins font-semibold text-lg text-brand-accent mb-3 leading-snug relative z-10 mt-10">
            {step.title}
          </h3>

          <!-- Description -->
          <p class="font-inter text-sm text-brand-muted leading-relaxed relative z-10">
            {step.description}
          </p>
        </div>
      ))}
    </div>

    <!-- Quote block — dark statement style -->
    <div class="mt-14 relative overflow-hidden rounded-[2rem]" style="background: #5B1FE8; border-left: 3px solid rgba(255,255,255,0.25);">
      <!-- Oversized decorative opening quote mark -->
      <div
        class="absolute font-poppins font-bold text-white pointer-events-none select-none"
        style="font-size: 180px; opacity: 0.05; top: -20px; left: 20px; line-height: 1;"
        aria-hidden="true"
      >"</div>

      <!-- Subtle depth gradient overlay -->
      <div
        class="absolute inset-0 pointer-events-none"
        style="background: radial-gradient(ellipse at 15% 85%, rgba(45,27,142,0.12) 0%, transparent 55%), radial-gradient(ellipse at 85% 15%, rgba(30,27,75,0.18) 0%, transparent 55%);"
      ></div>

      <!-- Quote text -->
      <div class="relative z-10 px-12 py-8">
        <p class="font-inter font-medium text-white leading-relaxed italic text-lg md:text-xl">
          "We don't sell you a stack of software and leave. We map your actual business first — then build what fits. Most clients see results inside the first month."
        </p>
      </div>
    </div>

  </div>

  <!-- Section transition gradient -->
  <div aria-hidden="true" class="absolute bottom-0 left-0 right-0 h-20 pointer-events-none" style="background: linear-gradient(to bottom, transparent, #F0EDE8);"></div>
</section>
