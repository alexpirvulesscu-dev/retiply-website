---
const steps = [
  {
    number: '01',
    title: 'Discovery Call',
    description:
      'A free 30-minute call where we listen to what is working, what is not, and tell you exactly where automation would make the biggest difference.',
  },
  {
    number: '02',
    title: 'Map the Workflow',
    description:
      'Together we outline the end-to-end workflow for your business. We decide which steps stay human and which ones get automated.',
  },
  {
    number: '03',
    title: 'Proposal',
    description:
      'A clear scope and fixed price built around your specific workflow. We include alternative approaches so you can choose what fits.',
  },
  {
    number: '04',
    title: 'Build and Deploy',
    description:
      'We build, test, and hand it over live. You get weekly progress updates and a system that actually runs — not a proposal that collects dust.',
  },
  {
    number: '05',
    title: 'Ongoing Support',
    description:
      'Optional ongoing support to keep your systems sharp. The longer it runs, the more it gives back.',
  },
];
---

<section class="relative py-24 px-6 bg-brand-surface">
  <div class="max-w-7xl mx-auto">

    <!-- Heading -->
    <div class="mb-14">
      <h2 class="font-inter font-bold text-brand-text" style="font-size: clamp(1.75rem, 4vw, 3rem); line-height: 1.1; margin: 0;">
        How We Work
      </h2>
      <p style="font-family: 'Inter', sans-serif; font-weight: 400; font-size: 1rem; color: #6B6B6B; margin-top: 12px;">From first conversation to working system.</p>
    </div>

    <!-- Steps -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-5">
      {steps.map((step) => (
        <div class="bg-brand-bg rounded-2xl p-7 relative overflow-hidden">
          <!-- Large faded step number — brand blue-purple, overlapping card text slightly -->
          <span
            class="absolute -top-2 right-2 font-poppins font-bold leading-none pointer-events-none select-none"
            style="font-size: 9rem; color: rgba(45,27,142,0.10); line-height: 1;"
          >
            {step.number}
          </span>

          <!-- Title -->
          <h3 class="font-poppins font-semibold text-xl text-brand-accent mb-3 leading-snug relative z-10 mt-10">
            {step.title}
          </h3>

          <!-- Description -->
          <p class="font-inter text-base text-brand-muted leading-relaxed relative z-10">
            {step.description}
          </p>
        </div>
      ))}
    </div>

  </div>

  <!-- Section transition gradient -->
  <div aria-hidden="true" class="absolute bottom-0 left-0 right-0 h-20 pointer-events-none" style="background: linear-gradient(to bottom, transparent, #E8E4DF);"></div>
</section>
