---
import WorkflowDiagram from './WorkflowDiagram.jsx';
---

<section class="relative overflow-hidden bg-brand-bg py-14 px-4">
  <!-- Dot grid — same as hero, no aurora -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background-image: radial-gradient(circle, rgba(0,0,0,0.20) 1px, transparent 1px); background-size: 28px 28px;"
  ></div>

  <!-- Heading + diagram -->
  <div class="relative z-10 w-full max-w-6xl mx-auto">
    <p class="section-label">How It Works</p>
    <h2 class="font-inter font-bold text-2xl md:text-3xl text-brand-text leading-tight mb-10">
      Stop paying for repetitive work.<br />We automate the hours your team loses every week.
    </h2>
    <WorkflowDiagram client:visible />
  </div>

  <!-- Section transition gradient -->
  <div aria-hidden="true" class="absolute bottom-0 left-0 right-0 h-20 pointer-events-none" style="background: linear-gradient(to bottom, transparent, #E8E4DF);"></div>
</section>
