---
const CALENDLY_URL = '#contact';

const navLinks = [
  { label: 'What We Do', href: '#services' },
  { label: 'How We Work', href: '#how-we-work' },
  { label: 'About Us', href: '#about' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="w-full px-[110px] py-4 flex items-center justify-between gap-8">

    <!-- Logo: left-aligned -->
    <a href="/" class="flex items-center flex-shrink-0">
      <img src="/logo-horizontal.png" alt="Retiply" class="h-14 w-auto" />
    </a>

    <!-- Centre nav links -->
    <div class="hidden md:flex items-center justify-center flex-1 gap-10">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="font-inter text-base font-semibold text-brand-text hover:text-brand-text/70 transition-colors duration-200"
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- CTA button: right-aligned, larger -->
    <a
      href={CALENDLY_URL}
      class="inline-flex items-center gap-3 bg-brand-accent text-white rounded-full pl-6 pr-2 py-2 font-inter font-semibold text-base hover:bg-brand-accent-light transition-colors duration-200 flex-shrink-0"
    >
      Book a Free Call
      <span class="w-9 h-9 bg-white rounded-full flex items-center justify-center flex-shrink-0">
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
          <path d="M2.5 7.5h10M8 3.5 12 7.5 8 11.5" stroke="#2D1B8E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </a>

  </div>
</nav>

<style>
  #navbar {
    background-color: transparent;
  }
  #navbar.scrolled {
    background-color: rgba(240, 237, 232, 0.96);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.06);
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  if (navbar) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 40) {
        navbar.classList.add('scrolled');
      } else {
        navbar.classList.remove('scrolled');
      }
    });
  }
</script>
