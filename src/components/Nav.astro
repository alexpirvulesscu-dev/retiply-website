---
// Replace CALENDLY_URL with your actual Calendly link before going live
const CALENDLY_URL = '#contact';

const navLinks = [
  { label: 'Services', href: '#services' },
  { label: 'How We Work', href: '#how-we-work' },
  { label: 'About', href: '#about' },
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-6 md:px-10 lg:px-16 py-4 flex items-center justify-between gap-8">

    <!-- Logo: 56px tall = clearly larger than the 44px Let's Talk button -->
    <a href="/" class="flex items-center flex-shrink-0">
      <img src="/logo-horizontal.png" alt="Retiply" class="h-14 w-auto" />
    </a>

    <!-- Category links (hidden on mobile) -->
    <div class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="font-inter text-sm font-medium text-brand-text/70 hover:text-brand-text transition-colors duration-200"
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- CTA button -->
    <a
      href={CALENDLY_URL}
      class="inline-flex items-center gap-3 bg-brand-accent text-white rounded-full pl-5 pr-1.5 py-1.5 font-inter font-medium text-sm hover:bg-brand-accent-light transition-colors duration-200 flex-shrink-0"
    >
      Let's Talk
      <span class="w-8 h-8 bg-white rounded-full flex items-center justify-center flex-shrink-0">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M2.5 7h9M7.5 3.5 11 7l-3.5 3.5" stroke="#2D1B8E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </a>

  </div>
</nav>

<style>
  #navbar {
    background-color: transparent;
  }
  #navbar.scrolled {
    background-color: rgba(240, 237, 232, 0.96);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 1px 0 rgba(0, 0, 0, 0.06);
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  if (navbar) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 40) {
        navbar.classList.add('scrolled');
      } else {
        navbar.classList.remove('scrolled');
      }
    });
  }
</script>
