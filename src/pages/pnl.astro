<style is:global>
  /* Scroll reveal — hidden initial state only when JS is active, so no-JS users see everything */
  .js main > section > div {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease-out, transform 0.5s ease-out;
    will-change: opacity, transform;
  }
  .js main > section > div.is-visible {
    opacity: 1;
    transform: none;
  }

  /* Proof strip: animate its items individually, so opt the container out of the block reveal */
  .js main > section > div.proof-strip {
    opacity: 1;
    transform: none;
  }
  .js .proof-item {
    opacity: 0;
    transform: translateY(12px);
  }
  .js .proof-item.is-in {
    opacity: 1;
    transform: none;
    transition: opacity 0.4s ease-out, transform 0.4s ease-out;
  }
  .js .proof-item:nth-child(2).is-in { transition-delay: 0.1s; }
  .js .proof-item:nth-child(3).is-in { transition-delay: 0.2s; }

  /* Check-circle pop, timed with each item */
  .js .proof-check {
    transform: scale(0);
    transform-origin: center;
  }
  .js .proof-item.is-in .proof-check {
    animation: proofCheckPop 0.4s ease-out both;
  }
  .js .proof-item:nth-child(2).is-in .proof-check { animation-delay: 0.1s; }
  .js .proof-item:nth-child(3).is-in .proof-check { animation-delay: 0.2s; }

  @keyframes proofCheckPop {
    0%   { transform: scale(0); }
    70%  { transform: scale(1.15); }
    100% { transform: scale(1); }
  }

  /* Value-block steps: staggered fade + slide-up, left to right */
  .js .step-item {
    opacity: 0;
    transform: translateY(16px);
  }
  .js .step-item.is-in {
    opacity: 1;
    transform: none;
    transition: opacity 0.5s ease-out, transform 0.5s ease-out;
  }
  .js .step-item:nth-child(2).is-in { transition-delay: 0.15s; }
  .js .step-item:nth-child(3).is-in { transition-delay: 0.3s; }

  /* Gentle hover lift — cards */
  @media (hover: hover) {
    .bg-white.rounded-2xl {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .bg-white.rounded-2xl:hover {
      transform: translateY(-3px);
      box-shadow: 0 22px 48px -20px rgba(0, 0, 0, 0.18) !important;
    }

    /* Gentle hover lift — buttons (keep the existing purple deepen animating too) */
    a.bg-brand-accent {
      transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
    }
    a.bg-brand-accent:hover {
      transform: translateY(-2px);
      box-shadow: 0 14px 30px -12px rgba(91, 31, 230, 0.5);
    }
  }

  /* Respect reduced-motion: no reveal offset, no hover movement */
  @media (prefers-reduced-motion: reduce) {
    .js main > section > div {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .js .proof-item,
    .js .proof-item.is-in {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .js .proof-check,
    .js .proof-item.is-in .proof-check {
      animation: none !important;
      transform: none !important;
    }
    .js .step-item,
    .js .step-item.is-in {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .bg-white.rounded-2xl:hover,
    a.bg-brand-accent:hover {
      transform: none !important;
    }
  }
</style>

<script>
  // Explainer video lightbox — open from the play button, close on backdrop / X / Escape
  const openBtn = document.getElementById('video-open');
  const lightbox = document.getElementById('video-lightbox');
  const closeBtn = document.getElementById('video-close');
  const video = document.getElementById('lightbox-video') as HTMLVideoElement | null;

  function openLightbox() {
    if (!lightbox) return;
    lightbox.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    video?.play().catch(() => {});
  }

  function closeLightbox() {
    if (!lightbox) return;
    lightbox.style.display = 'none';
    document.body.style.overflow = '';
    if (video) {
      video.pause();
      video.currentTime = 0;
    }
  }

  openBtn?.addEventListener('click', openLightbox);
  closeBtn?.addEventListener('click', closeLightbox);

  // Click on the dark backdrop (but not the video) closes it
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  // Escape key closes it
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && lightbox && lightbox.style.display === 'flex') {
      closeLightbox();
    }
  });

  // Scroll reveal — fade + gentle slide-up once, as each section's content enters view
  const revealEls = document.querySelectorAll('main > section > div');
  if ('IntersectionObserver' in window) {
    const revealObserver = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          obs.unobserve(entry.target);
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
    );
    revealEls.forEach((el) => revealObserver.observe(el));
  } else {
    // No observer support — show everything immediately
    revealEls.forEach((el) => el.classList.add('is-visible'));
  }

  // Proof strip — staggered fade-in + check-circle pop, once when it enters view
  const proofStrip = document.getElementById('proof-strip');
  if (proofStrip) {
    const proofItems = proofStrip.querySelectorAll('.proof-item');
    const playProof = () => proofItems.forEach((item) => item.classList.add('is-in'));

    if ('IntersectionObserver' in window) {
      const proofObserver = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            playProof();
            obs.disconnect();
          });
        },
        { threshold: 0.4 }
      );
      proofObserver.observe(proofStrip);
    } else {
      playProof();
    }
  }

  // Value-block steps — staggered fade-in left to right, once when the row enters view
  const stepsRow = document.getElementById('steps-row');
  if (stepsRow) {
    const stepItems = stepsRow.querySelectorAll('.step-item');
    const playSteps = () => stepItems.forEach((item) => item.classList.add('is-in'));

    if ('IntersectionObserver' in window) {
      const stepsObserver = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            playSteps();
            obs.disconnect();
          });
        },
        { threshold: 0.3 }
      );
      stepsObserver.observe(stepsRow);
    } else {
      playSteps();
    }
  }
</script>
