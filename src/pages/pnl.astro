---
import BaseLayout from '../layouts/BaseLayout.astro';

// Same Calendly popup pattern used across the site
const calendlyClick = "Calendly.initPopupWidget({url: 'https://calendly.com/retiply/30min', color: '#5B1FE6', textColor: '#ffffff'}); return false;";

// Problem section — "the old way" pain points
const oldWay = [
  'You chase invoices and update spreadsheets by hand',
  'Your real profit is always weeks out of date',
  'You find out a job lost money once it\'s too late to act',
  'Every month-end is a scramble to work out what actually happened',
];

// How it works — 3 steps
const steps = [
  {
    number: '01',
    title: 'You drop it in',
    description: "Drag an invoice or receipt into one folder. That's the whole job.",
  },
  {
    number: '02',
    title: 'The AI does the rest',
    description: 'It reads every detail, tags it to the right project and cost centre, and files it. No manual entry.',
  },
  {
    number: '03',
    title: 'Your numbers go live',
    description: 'Revenue, costs, profit, VAT and full P&L update the instant a record lands.',
  },
];

---

<BaseLayout
  title="P&L Automation | Retiply"
  description="We build you a financial system that pulls every invoice, tags every cost, and updates your profit the instant a record lands. Live in under 10 working days."
>
  <div style="background-color: #F6F4F9;">

    <!-- Mark JS as active before sections paint, so scroll-reveal never flashes and no-JS users still see all content -->
    <script is:inline>
      document.documentElement.classList.add('js');
    </script>

    <!-- Header: logo left, CTA right -->
    <header class="w-full px-6 md:px-12 py-6 flex items-center justify-between gap-4">
      <a href="/" class="inline-flex items-center">
        <img src="/logo-horizontal.png" alt="Retiply" class="h-10 md:h-12 w-auto" />
      </a>
      <a
        href="#"
        onclick={calendlyClick}
        class="hidden sm:inline-flex items-center bg-brand-accent text-white rounded-full font-inter font-medium hover:bg-brand-accent-light transition-colors duration-200"
        style="padding: 10px 22px; font-size: 0.95rem;"
      >
        Book a free 30-minute discovery call
      </a>
    </header>

    <main>

      <!-- 1. Hero — split: copy left, dashboard right, centred to fit the fold -->
      <section class="px-6 md:px-8 py-10 lg:py-0 lg:flex lg:items-center lg:min-h-[calc(100vh-300px)]">
        <div class="w-full max-w-[1600px] mx-auto grid grid-cols-1 lg:grid-cols-[660px_1fr] gap-12 lg:gap-16 items-center">

          <!-- LEFT: copy -->
          <div class="text-left">
            <span class="font-inter font-semibold text-xs md:text-sm tracking-[0.12em] uppercase text-brand-muted">
              Built by people who've run real businesses
            </span>

            <h1
              class="mt-5 max-w-[40rem] text-[2.25rem] md:text-[3rem] lg:text-[3.25rem] tracking-tight text-balance"
              style="font-family: 'DM Sans', sans-serif; font-weight: 700; color: #0A0A0A; line-height: 1.1;"
            >
              See your real profit in real time, with almost none of the work.
            </h1>

            <p class="mt-5 max-w-xl font-inter text-lg md:text-xl leading-relaxed" style="color: #6B6B6B;">
              Just drag an invoice into a folder. AI reads it, categorises it, and updates your
              live P&amp;L in seconds. A system built around how your business actually runs.
            </p>

            <div class="mt-8">
              <a
                href="#"
                onclick={calendlyClick}
                class="inline-flex items-center bg-brand-accent text-white rounded-full font-inter font-medium hover:bg-brand-accent-light transition-colors duration-200"
                style="padding: 14px 30px; font-size: 1.05rem;"
              >
                Book a free 30-minute discovery call
              </a>
            </div>

            <p class="mt-5 flex items-center gap-2.5 font-inter font-bold text-lg md:text-xl leading-relaxed" style="color: #0A0A0A;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="flex-shrink-0">
                <circle cx="12" cy="12" r="11" fill="#5B1FE6" />
                <path d="M7 12.5 10.5 16 17 8.5" stroke="#FFFFFF" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span>Free call. And a <span style="color: #5B1FE6;">money-back guarantee</span> on every build.</span>
            </p>
          </div>

          <!-- RIGHT: explainer video with poster + purple play button -->
          <button
            id="video-open"
            type="button"
            aria-label="Play explainer video"
            class="group relative block rounded-2xl overflow-hidden cursor-pointer leading-none w-full"
            style="box-shadow: 0 30px 60px -22px rgba(0,0,0,0.28);"
          >
            <img
              src="/pnl/dashboard.png"
              alt="Retiply explainer — live P&amp;L dashboard showing profit, job margins, and cash flow"
              class="block w-full h-auto"
              loading="eager"
            />
            <span class="absolute inset-0 flex items-center justify-center">
              <span
                class="flex items-center justify-center rounded-full shadow-xl transition-transform duration-200 group-hover:scale-110"
                style="width: 72px; height: 72px; background-color: #5B1FE6;"
              >
                <svg width="28" height="28" viewBox="0 0 24 24" fill="#FFFFFF" aria-hidden="true">
                  <path d="M8 5v14l11-7z" />
                </svg>
              </span>
            </span>
          </button>

        </div>
      </section>

      <!-- Social proof strip — full-width band, three check-circle items -->
      <section class="px-6 md:px-12 py-6 border-y border-black/5 lg:mt-4">
        <div id="proof-strip" class="proof-strip max-w-[1400px] mx-auto flex flex-col sm:flex-row items-center justify-center gap-5 sm:gap-12 font-inter text-base md:text-lg" style="color: #4A4A4A;">
          <span class="proof-item inline-flex items-center gap-2.5">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="proof-check flex-shrink-0">
              <circle cx="12" cy="12" r="11" fill="#5B1FE6" />
              <path d="M7 12.5 10.5 16 17 8.5" stroke="#FFFFFF" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span><strong style="color: #5B1FE6; font-weight: 700;">£40k</strong> saved, Aton Grid</span>
          </span>
          <span class="proof-item inline-flex items-center gap-2.5">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="proof-check flex-shrink-0">
              <circle cx="12" cy="12" r="11" fill="#5B1FE6" />
              <path d="M7 12.5 10.5 16 17 8.5" stroke="#FFFFFF" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span><strong style="color: #5B1FE6; font-weight: 700;">14 hrs/week</strong> back, Socend Construct</span>
          </span>
          <span class="proof-item inline-flex items-center gap-2.5">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="proof-check flex-shrink-0">
              <circle cx="12" cy="12" r="11" fill="#5B1FE6" />
              <path d="M7 12.5 10.5 16 17 8.5" stroke="#FFFFFF" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>Full visibility, <strong style="color: #5B1FE6; font-weight: 700;">no new hire</strong>, Dental Studio</span>
          </span>
        </div>
      </section>

      <!-- Social proof — testimonials + credibility, consolidated here -->
      <section class="px-6 md:px-12 pt-20 md:pt-28 pb-6">
        <div class="max-w-[1400px] mx-auto">
          <h2
            class="text-center text-[1.75rem] md:text-[2.75rem]"
            style="font-family: 'DM Sans', sans-serif; font-weight: 700; color: #0A0A0A; line-height: 1.15;"
          >
            What people are saying
          </h2>

          <div class="mt-14 grid grid-cols-1 md:grid-cols-3 gap-6">

            <!-- Card 1 — testimonial -->
            <div class="bg-white rounded-2xl p-8 border border-black/5 flex flex-col" style="box-shadow: 0 14px 34px -16px rgba(0,0,0,0.14);">
              <div class="flex gap-1 mb-5" aria-label="5 out of 5 stars">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#5B1FE6" aria-hidden="true"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#5B1FE6" aria-hidden="true"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#5B1FE6" aria-hidden="true"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#5B1FE6" aria-hidden="true"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#5B1FE6" aria-hidden="true"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
              </div>
              <p class="font-inter text-lg leading-relaxed" style="color: #2A2A2A;">
                “We caught a job running at a loss in month two and renegotiated the remaining works
                back to breakeven. That saved us around £40,000 we'd never have seen coming until handover.”
              </p>
              <div class="mt-auto">
                <div class="my-6 border-t border-black/10"></div>
                <p style="font-family: 'DM Sans', sans-serif; font-weight: 700; color: #0A0A0A;">Nick</p>
                <p class="font-inter text-sm mt-0.5" style="color: #6B6B6B;">Aton Grid</p>
                <p class="font-inter text-sm font-bold mt-3" style="color: #5B1FE6;">£40,000 saved</p>
              </div>
            </div>

            <!-- Card 2 — testimonial -->
            <div class="bg-white rounded-2xl p-8 border border-black/5 flex flex-col" style="box-shadow: 0 14px 34px -16px rgba(0,0,0,0.14);">
              <div class="flex gap-1 mb-5" aria-label="5 out of 5 stars">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#5B1FE6" aria-hidden="true"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#5B1FE6" aria-hidden="true"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#5B1FE6" aria-hidden="true"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#5B1FE6" aria-hidden="true"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#5B1FE6" aria-hidden="true"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
              </div>
              <p class="font-inter text-lg leading-relaxed" style="color: #2A2A2A;">
                “I used to spend hours every week making sure our financial data was right.
                It never gave me the confidence it was. Now it just happens, and I always know where we stand.”
              </p>
              <div class="mt-auto">
                <div class="my-6 border-t border-black/10"></div>
                <p style="font-family: 'DM Sans', sans-serif; font-weight: 700; color: #0A0A0A;">Daniel</p>
                <p class="font-inter text-sm mt-0.5" style="color: #6B6B6B;">Socend Construct</p>
                <p class="font-inter text-sm font-bold mt-3" style="color: #5B1FE6;">14 hours back every week</p>
              </div>
            </div>

            <!-- Card 3 — testimonial -->
            <div class="bg-white rounded-2xl p-8 border border-black/5 flex flex-col" style="box-shadow: 0 14px 34px -16px rgba(0,0,0,0.14);">
              <div class="flex gap-1 mb-5" aria-label="5 out of 5 stars">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#5B1FE6" aria-hidden="true"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#5B1FE6" aria-hidden="true"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#5B1FE6" aria-hidden="true"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#5B1FE6" aria-hidden="true"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="#5B1FE6" aria-hidden="true"><path d="M12 17.27 18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
              </div>
              <p class="font-inter text-lg leading-relaxed" style="color: #2A2A2A;">
                “To see where our money went, we'd have had to hire someone. So we never did.
                Now we drag everything into a folder and seconds later I can see where we're losing money.
                Every business owner needs this.”
              </p>
              <div class="mt-auto">
                <div class="my-6 border-t border-black/10"></div>
                <p style="font-family: 'DM Sans', sans-serif; font-weight: 700; color: #0A0A0A;">Christina</p>
                <p class="font-inter text-sm mt-0.5" style="color: #6B6B6B;">Dental Studio</p>
                <p class="font-inter text-sm font-bold mt-3" style="color: #5B1FE6;">No extra hire. Full visibility.</p>
              </div>
            </div>

          </div>

          <!-- CTA -->
          <div class="mt-12 text-center">
            <a
              href="#"
              onclick={calendlyClick}
              class="inline-flex items-center bg-brand-accent text-white rounded-full font-inter font-medium hover:bg-brand-accent-light transition-colors duration-200"
              style="padding: 14px 30px; font-size: 1.05rem;"
            >
              Book a free 30-minute discovery call
            </a>
          </div>
        </div>
      </section>

      <!-- 3. How it works — full-width steps -->
      <section class="px-6 md:px-12 pt-20 md:pt-28 pb-6">
        <div class="max-w-[1400px] mx-auto">

          <!-- Heading + sub, centred -->
          <div class="max-w-3xl mx-auto text-center">
            <h2
              class="text-[1.6rem] md:text-[2.25rem] tracking-tight"
              style="font-family: 'DM Sans', sans-serif; font-weight: 700; color: #0A0A0A; line-height: 1.15;"
            >
              Almost none of the work. All of the visibility.
            </h2>

            <p class="mt-3 font-inter text-base md:text-lg leading-relaxed" style="color: #6B6B6B;">
              You handle the 30 seconds of dropping a file in. The AI handles everything after.
            </p>
          </div>

          <!-- Steps row — glass icon tiles in a connected sequence -->
          <div id="steps-row" class="mt-16 max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-6">
            {steps.map((step, i) => (
              <div class="step-item relative flex flex-col items-center text-center">

                {/* Glass icon tile + connecting track (track lives in this row so it stays aligned) */}
                <div class="relative w-full flex justify-center">
                  {i < steps.length - 1 && (
                    <span
                      class="hidden md:block absolute"
                      style="top: 50%; transform: translateY(-50%); left: calc(50% + 40px); width: calc(100% - 56px); height: 3px; border-radius: 2px; background-color: rgba(91,31,230,0.28); z-index: 0;"
                      aria-hidden="true"
                    ></span>
                  )}
                  <div
                    class="relative flex items-center justify-center"
                    style="width: 80px; height: 80px; border-radius: 20px; background: linear-gradient(160deg, rgba(124,77,240,0.22) 0%, rgba(91,31,230,0.08) 100%); border: 1px solid rgba(91,31,230,0.22); box-shadow: 0 14px 28px -10px rgba(91,31,230,0.32), 0 3px 8px -3px rgba(91,31,230,0.20), inset 0 1px 1px rgba(255,255,255,0.70), inset 0 -8px 18px rgba(91,31,230,0.10); backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); z-index: 10;"
                  >
                    {i === 0 && (
                      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#5B1FE6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="block" aria-hidden="true">
                        <path d="M12 3v11" />
                        <path d="M8 10l4 4 4-4" />
                        <path d="M5 17v2a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-2" />
                      </svg>
                    )}
                    {i === 1 && (
                      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#5B1FE6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="block" aria-hidden="true">
                        <path d="M12 5l1.6 5.4L19 12l-5.4 1.6L12 19l-1.6-5.4L5 12l5.4-1.6z" />
                      </svg>
                    )}
                    {i === 2 && (
                      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#5B1FE6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="block" aria-hidden="true">
                        <path d="M4 5v14h16" />
                        <path d="M7 14l3.5-3.5 3 3L20 7" />
                        <path d="M16 7h4v4" />
                      </svg>
                    )}
                  </div>
                </div>

                <!-- Step number — small purple caption -->
                <p class="mt-5 font-inter text-xs font-bold tracking-[0.16em] uppercase" style="color: #5B1FE6;">
                  Step {step.number}
                </p>
                <h3 class="mt-1 font-poppins font-semibold text-xl leading-snug" style="color: #0A0A0A;">
                  {step.title}
                </h3>
                <p class="mt-2 font-inter text-base leading-relaxed" style="color: #6B6B6B;">
                  {step.description}
                </p>
              </div>
            ))}
          </div>

          <!-- CTA -->
          <div class="mt-14 text-center">
            <a
              href="#"
              onclick={calendlyClick}
              class="inline-flex items-center bg-brand-accent text-white rounded-full font-inter font-medium hover:bg-brand-accent-light transition-colors duration-200"
              style="padding: 14px 30px; font-size: 1.05rem;"
            >
              Book a free 30-minute discovery call
            </a>
          </div>

        </div>
      </section>

      <!-- Video lightbox — opened by the play button (vanilla JS) -->
      <div
        id="video-lightbox"
        class="fixed inset-0 z-[100] items-center justify-center p-4"
        style="display: none; background: rgba(0,0,0,0.8);"
      >
        <div class="relative w-[80vw] max-w-[900px]">
          <button
            id="video-close"
            type="button"
            aria-label="Close video"
            class="absolute -top-11 right-0 flex items-center justify-center w-9 h-9 rounded-full bg-white/10 hover:bg-white/20 transition-colors duration-200"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <line x1="6" y1="6" x2="18" y2="18" />
              <line x1="18" y1="6" x2="6" y2="18" />
            </svg>
          </button>
          <video
            id="lightbox-video"
            controls
            playsinline
            preload="none"
            poster="/pnl/dashboard.png"
            class="w-full rounded-xl block bg-black"
            style="max-height: 80vh;"
          >
            <source src="/pnl/explainer.mp4" type="video/mp4" />
            Your browser does not support the video tag.
          </video>
        </div>
      </div>

      <!-- 2. Problem + Guarantee — side by side -->
      <section class="px-6 md:px-12 pt-20 md:pt-28 pb-6">
        <div class="max-w-[1400px] mx-auto grid grid-cols-1 lg:grid-cols-[58fr_42fr] gap-8 lg:gap-10 items-stretch">

          <!-- LEFT: old-way vs Retiply-way comparison -->
          <div class="text-left">
            <h2
              class="text-[1.75rem] md:text-[2.5rem]"
              style="font-family: 'DM Sans', sans-serif; font-weight: 700; color: #0A0A0A; line-height: 1.15;"
            >
              Your accounts keep you compliant. They don't tell you if you're making money.
            </h2>

            <!-- Lead line -->
            <p class="mt-4 font-inter text-lg md:text-xl leading-relaxed" style="color: #6B6B6B;">
              You're making weekly decisions on numbers that are weeks out of date.
            </p>

            <!-- The old way -->
            <div class="mt-8 bg-white rounded-2xl border border-black/5 p-7 md:p-8" style="box-shadow: 0 14px 34px -18px rgba(0,0,0,0.12);">
              <p class="font-inter font-semibold text-xs tracking-[0.12em] uppercase" style="color: #9A95A1;">
                The old way
              </p>
              <ul class="mt-5 flex flex-col gap-3.5">
                {oldWay.map((item) => (
                  <li class="flex items-start gap-3">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="flex-shrink-0 mt-1">
                      <path d="M4 4l8 8M12 4l-8 8" stroke="#C0564B" stroke-width="1.8" stroke-linecap="round" />
                    </svg>
                    <span class="font-inter text-base md:text-lg leading-relaxed" style="color: #5A5560;">
                      {item}
                    </span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- The Retiply way -->
            <div class="mt-6 rounded-2xl p-7 md:p-8" style="background-color: rgba(91,31,230,0.05); border-left: 3px solid #5B1FE6;">
              <p class="flex items-center gap-2 font-inter font-semibold text-xs tracking-[0.12em] uppercase" style="color: #6B6B6B;">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="flex-shrink-0">
                  <path d="M3.5 8.5 7 12l5.5-7" stroke="#2E8B57" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                The Retiply way
              </p>
              <p class="mt-3 font-inter text-lg md:text-xl font-semibold leading-relaxed" style="color: #0A0A0A;">
